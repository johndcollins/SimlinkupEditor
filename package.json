{
  "name": "simlinkup-profile-editor",
  "version": "1.0.0",
  "author": "SimLinkup",
  "description": "SimLinkup profile editor — create and manage custom mapping profiles with Simtek instruments",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "make": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.simlinkup.profileeditor",
    "productName": "SimLinkup Profile Editor",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}